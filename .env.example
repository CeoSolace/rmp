NEXT_PUBLIC_APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=69dff0e000135c23546c
NEXT_PUBLIC_APPWRITE_PROJECT_NAME=Appwrite Project
NEXT_PUBLIC_APP_URL=http://rampchat.xyz
NEXT_PUBLIC_OWNER_EMAIL=owner@rampchat.dev

OWNER_EMAIL=owner@rampchat.dev
OWNER_PASSWORD=ChangeMeNow123!

# Cloudinary credentials for server-side upload. Do not expose the secret
# key on the client side. Provide NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME for
# client-side usage of Cloudinary if needed.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# Default Cloudinary folder to store uploaded images.
CLOUDINARY_FOLDER=rampchat

NODE_ENV=production
PORT=10000